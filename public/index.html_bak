<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GoalScout — Match Investigation Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{--bg:#070d16;--panel:#08101b;--panel-2:#0b1220;--panel-3:#0f1828;--text:#e5edf8;--muted:#8b9ab0;--muted-2:#66758c;--line:rgba(255,255,255,0.08);--green:#6ee7b7;--lime:#bef264;--amber:#fbbf24;--red:#f87171;--cyan:#67e8f9;--violet:#c4b5fd;--blue:#7dd3fc;--indigo:#818cf8}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:Inter,system-ui,sans-serif;background:var(--bg);color:var(--text)}
.app{max-width:1400px;margin:0 auto;padding:20px 20px 40px}

/* ── Hero ── */
.hero{border:1px solid var(--line);border-radius:28px;padding:24px;background:radial-gradient(circle at top left,rgba(34,197,94,.12),transparent 22%),radial-gradient(circle at top right,rgba(59,130,246,.12),transparent 24%),linear-gradient(180deg,#0b1322,#09101c);box-shadow:0 20px 60px rgba(0,0,0,.35)}
.hero-inner{display:flex;justify-content:space-between;align-items:center;gap:24px;flex-wrap:wrap}
.brand{display:flex;align-items:center;gap:12px;margin-bottom:8px}
.brand h1{font-size:28px;font-weight:700;letter-spacing:-0.03em;color:#a7f3d0}
.brand h1 span{color:#64748b;font-weight:500}
.pill{display:inline-flex;align-items:center;border:1px solid var(--line);background:rgba(255,255,255,.05);color:#94a3b8;border-radius:999px;padding:6px 12px;font-size:11px;text-transform:uppercase;letter-spacing:.22em}
.hero p{max-width:700px;font-size:13px;color:#94a3b8;line-height:1.5}
.hero-right{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.status{display:flex;align-items:center;gap:10px;border:1px solid var(--line);background:rgba(255,255,255,.04);padding:12px 16px;border-radius:16px;color:#cbd5e1;font-size:13px}
.dot{width:9px;height:9px;border-radius:999px;background:#4ade80;box-shadow:0 0 14px rgba(74,222,128,.9)}
.dot.running{background:var(--amber);animation:pulse 1s infinite}
.dot.error{background:var(--red)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.btn{border:1px solid rgba(52,211,153,.3);background:rgba(16,185,129,.15);color:#d1fae5;padding:12px 18px;border-radius:16px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;transition:background .15s}
.btn:hover{background:rgba(16,185,129,.25)}.btn:disabled{opacity:.5;cursor:not-allowed}
.loading-bar{height:2px;background:var(--line);overflow:hidden;position:relative}
.loading-bar.active::after{content:'';position:absolute;left:-40%;width:40%;height:100%;background:var(--green);animation:loading 1.2s ease-in-out infinite}
@keyframes loading{0%{left:-40%}100%{left:100%}}

/* ── Stats + Filters ── */
.stats{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:16px;max-width:500px}
.stat{border-radius:20px;border:1px solid var(--line);padding:18px}
.stat-label{font-size:11px;text-transform:uppercase;letter-spacing:.22em;color:var(--muted-2)}
.stat-value{margin-top:10px;font-size:32px;font-weight:700;letter-spacing:-.03em}
.tone-amber{background:rgba(245,158,11,.10);border-color:rgba(251,191,36,.2)}
.tone-blue{background:rgba(59,130,246,.10);border-color:rgba(125,211,252,.2)}
.filters{margin-top:16px;border-radius:22px;border:1px solid var(--line);background:var(--panel-2);padding:14px 16px}
.filters-inner{display:flex;justify-content:space-between;align-items:center;gap:14px;flex-wrap:wrap}
.filter-row{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
.filter-group{display:flex;align-items:center;gap:7px}
.filter-label{font-size:11px;text-transform:uppercase;letter-spacing:.22em;color:var(--muted-2)}
.filter-chip{border:1px solid var(--line);background:rgba(255,255,255,.03);color:#cbd5e1;padding:8px 11px;border-radius:10px;font-size:13px;cursor:pointer;font-family:inherit;transition:all .12s}
.filter-chip.active{border-color:rgba(52,211,153,.3);background:rgba(16,185,129,.15);color:#bbf7d0}
.filter-chip:hover{border-color:rgba(255,255,255,.15)}
.league-select{border:1px solid var(--line);background:var(--panel-3);color:#cbd5e1;padding:12px 14px;border-radius:14px;font-size:13px;font-family:inherit}

/* ── Tab buttons ── */
.tab-btn{border:1px solid var(--line);background:rgba(255,255,255,.04);color:#94a3b8;padding:9px 16px;border-radius:12px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .12s}
.tab-btn.active{border-color:rgba(52,211,153,.3);background:rgba(16,185,129,.15);color:#bbf7d0}
.tab-btn:hover:not(.active){border-color:rgba(255,255,255,.15);color:#e2e8f0}

/* ── Accordion shortlist ── */
.shortlist-wrap{margin-top:14px;border:1px solid var(--line);border-radius:26px;background:var(--panel);overflow:hidden;box-shadow:0 24px 80px rgba(0,0,0,.28)}

/* Summary row (always visible) */
.match-row{border-bottom:1px solid rgba(255,255,255,.06);cursor:pointer;transition:background .1s}
.match-row:last-child{border-bottom:none}
.match-row:hover .row-summary{background:rgba(255,255,255,.025)}
.match-row.open .row-summary{background:rgba(255,255,255,.04)}
.match-row.open{border-bottom-color:rgba(255,255,255,.10)}

.row-summary{display:grid;align-items:center;gap:12px;padding:14px 18px;grid-template-columns:72px 52px 58px 90px minmax(100px,160px) 1fr 110px 90px 22px;transition:background .1s}
/* Sort header bar */
.sort-bar{display:grid;align-items:center;gap:12px;padding:10px 18px;grid-template-columns:72px 52px 58px 90px minmax(100px,160px) 1fr 110px 90px 22px;border-bottom:1px solid var(--line);background:rgba(255,255,255,.04)}
.sort-btn{font-size:10px;text-transform:uppercase;letter-spacing:.16em;color:#94a3b8;cursor:pointer;user-select:none;background:none;border:none;font-family:inherit;padding:0;text-align:left;display:flex;align-items:center;gap:4px;transition:color .12s;white-space:nowrap}
.sort-btn:hover{color:#cbd5e1}
.sort-btn.asc::after{content:' ▲';font-size:8px;color:var(--green)}
.sort-btn.desc::after{content:' ▼';font-size:8px;color:var(--green)}
.sort-label{font-size:10px;text-transform:uppercase;letter-spacing:.16em;color:#94a3b8;white-space:nowrap}
.col-odds-summary .odds-box,.col-odds-summary .odds-box-u25{padding:6px 9px;border-radius:10px}
.col-odds-summary .odds-price,.col-odds-summary .odds-price-u25{font-size:16px}
.col-odds-summary .odds-label{font-size:9px}
.col-edge-summary .edge-box{padding:6px 9px;border-radius:10px;min-width:0}
.col-edge-summary .edge-val{font-size:14px}
.col-edge-summary .edge-label{font-size:9px}
.col-odds-summary,.col-edge-summary{font-size:12px;color:var(--muted-2)}
.col-prob .prob-big{font-size:22px;font-weight:700;letter-spacing:-.02em}
.col-prob .prob-sub{font-size:10px;color:var(--muted-2);margin-top:1px}
.badge{display:inline-flex;align-items:center;justify-content:center;min-width:36px;padding:6px 10px;border-radius:10px;font-size:12px;font-weight:700}
.grade-aplus{border:1px solid rgba(74,222,128,.3);background:rgba(16,185,129,.15);color:#6ee7b7}
.grade-a{border:1px solid rgba(190,242,100,.3);background:rgba(132,204,22,.14);color:#bef264}
.grade-b{border:1px solid rgba(251,191,36,.3);background:rgba(245,158,11,.15);color:#fcd34d}
.grade-c{border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.04);color:#94a3b8}
.dir-badge{display:inline-flex;align-items:center;padding:5px 9px;border-radius:8px;font-size:11px;font-weight:700;letter-spacing:.04em;text-transform:uppercase}
.dir-o25{border:1px solid rgba(110,231,183,.3);background:rgba(16,185,129,.12);color:#6ee7b7}
.dir-u25{border:1px solid rgba(129,140,248,.3);background:rgba(99,102,241,.12);color:#818cf8}
.col-ko{font-size:13px;color:#cbd5e1;line-height:1.4}
.col-ko .ko-date{font-size:11px;color:var(--muted-2)}
.col-league span{display:inline-block;border:1px solid var(--line);background:rgba(255,255,255,.03);padding:5px 9px;border-radius:9px;font-size:11px;color:#cbd5e1;max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.col-match .match-title{font-size:14px;font-weight:600;letter-spacing:-.01em}
.col-match .match-league-hint{font-size:11px;color:var(--muted-2);margin-top:2px}
.chevron{color:var(--muted-2);font-size:14px;transition:transform .2s;line-height:1;text-align:right}
.match-row.open .chevron{transform:rotate(180deg)}

/* Expanded detail panel */
.row-detail{display:none;border-top:1px solid rgba(255,255,255,.08);background:rgba(0,0,0,.18)}
.match-row.open .row-detail{display:block}
.detail-inner{padding:18px 22px 20px;display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:16px}
.detail-section{display:flex;flex-direction:column;gap:8px}
.detail-section-title{font-size:10px;text-transform:uppercase;letter-spacing:.2em;color:var(--muted-2);margin-bottom:4px}

/* Stat boxes inside detail */
.stat-box{border:1px solid rgba(103,232,249,.10);background:rgba(6,182,212,.05);border-radius:12px;padding:10px 12px}
.stat-box-u25{border:1px solid rgba(129,140,248,.15);background:rgba(99,102,241,.06);border-radius:12px;padding:10px 12px}
.stat-box-label{font-size:10px;text-transform:uppercase;letter-spacing:.18em;color:var(--muted-2)}
.stat-box-val{font-size:15px;font-weight:700;margin-top:3px;letter-spacing:-.01em}
.pct-hot{color:var(--green)}.pct-warm{color:var(--amber)}.pct-cold{color:var(--muted)}

/* Odds + edge in detail */
.odds-box{border:1px solid rgba(196,181,253,.2);background:rgba(139,92,246,.08);border-radius:12px;padding:10px 12px}
.odds-box-u25{border:1px solid rgba(129,140,248,.25);background:rgba(99,102,241,.10);border-radius:12px;padding:10px 12px}
.odds-price{font-size:20px;font-weight:700;color:var(--violet)}
.odds-price-u25{font-size:20px;font-weight:700;color:var(--indigo)}
.odds-label{font-size:10px;color:var(--muted-2);margin-top:2px;text-transform:uppercase;letter-spacing:.1em}
.edge-box{border:1px solid rgba(103,232,249,.15);background:rgba(6,182,212,.06);border-radius:12px;padding:10px 12px}
.edge-val{font-size:18px;font-weight:700;margin-top:2px}
.edge-label{font-size:10px;color:var(--muted-2);text-transform:uppercase;letter-spacing:.15em}

/* Flags in detail */
.flags{display:flex;flex-wrap:wrap;gap:5px}
.flag{border:1px solid rgba(74,222,128,.2);background:rgba(16,185,129,.10);color:#d1fae5;border-radius:999px;padding:4px 9px;font-size:11px}
.flag.warn{border-color:rgba(248,113,113,.2);background:rgba(239,68,68,.10);color:#fecaca}
.flag.hot{border-color:rgba(74,222,128,.35);background:rgba(16,185,129,.2);color:#a7f3d0}
.flag.lock{border-color:rgba(129,140,248,.3);background:rgba(99,102,241,.12);color:#a5b4fc}

/* Links in detail */
.links{display:flex;flex-direction:column;gap:6px;align-items:flex-start}
.action{border:1px solid var(--line);background:rgba(255,255,255,.04);color:#ddd6fe;border-radius:9px;padding:8px 12px;font-size:12px;text-decoration:none;width:100%;text-align:center;display:block;transition:border-color .1s}
.action:hover{border-color:rgba(255,255,255,.15);color:#f8fafc}

/* Probability fair sub-row */
.prob-fair{font-size:11px;color:var(--muted-2)}

/* ── Empty state ── */
.empty-state{text-align:center;padding:4rem 2rem;color:var(--muted)}.empty-state h2{font-size:16px;color:var(--text);margin-bottom:8px}

/* ── Performance tab ── */
.perf-market-panel{border:1px solid var(--line);border-radius:20px;background:var(--panel);padding:18px}
.perf-card{border:1px solid var(--line);border-radius:14px;padding:14px 16px;background:var(--panel-2)}
.perf-card-label{font-size:11px;text-transform:uppercase;letter-spacing:.2em;color:var(--muted-2)}
.perf-card-value{font-size:26px;font-weight:700;letter-spacing:-.03em;margin-top:8px}
.perf-card-sub{font-size:11px;color:var(--muted-2);margin-top:3px}
.perf-row{display:flex;justify-content:space-between;padding:8px 0;border-top:1px solid rgba(255,255,255,.06);font-size:13px}
.perf-row:first-of-type{border-top:0}
.perf-row-label{color:var(--muted)}
.perf-row-val{font-weight:700}
.market-tabs{display:flex;gap:8px;padding:14px 18px 0;border-bottom:1px solid var(--line)}
.market-tab{border:none;background:none;color:var(--muted-2);font-size:13px;font-weight:600;padding:7px 14px 12px;cursor:pointer;font-family:inherit;border-bottom:2px solid transparent;margin-bottom:-1px;transition:color .15s,border-color .15s}
.market-tab.active{color:var(--green);border-bottom-color:var(--green)}
.market-tab.active-u25{color:var(--indigo);border-bottom-color:var(--indigo)}
.market-tab:hover:not(.active):not(.active-u25){color:var(--text)}

/* ── Perf table ── */
.perf-table-wrap{overflow-x:auto}
.perf-table{width:100%;border-collapse:collapse;min-width:1000px}
.perf-table th{padding:11px 10px;font-size:11px;text-transform:uppercase;letter-spacing:.15em;color:var(--muted-2);text-align:left;border-bottom:1px solid var(--line);white-space:nowrap}
.perf-table td{padding:11px 10px;font-size:13px;border-bottom:1px solid rgba(255,255,255,.05)}
.perf-table tr:last-child td{border-bottom:none}

/* ── Tooltip ── */
.tip{position:relative;display:inline-flex}
.tip .tip-text{visibility:hidden;background:#1e293b;color:#e2e8f0;font-size:12px;font-weight:400;letter-spacing:0;text-transform:none;padding:9px 13px;border-radius:10px;border:1px solid rgba(255,255,255,.12);position:absolute;z-index:9999;top:100%;left:50%;transform:translateX(-50%);margin-top:6px;width:240px;line-height:1.5;white-space:normal;box-shadow:0 8px 24px rgba(0,0,0,.4);pointer-events:none}
.tip:hover .tip-text{visibility:visible}

/* ── Footer ── */
.footer{margin-top:16px;border-top:1px solid var(--line);padding:16px 0;display:flex;justify-content:space-between;font-size:12px;color:var(--muted-2);flex-wrap:wrap;gap:8px}
.footer a{color:var(--violet);text-decoration:none}

@media(max-width:768px){
  .stats{grid-template-columns:1fr}
  .row-summary{grid-template-columns:64px 44px 52px 1fr 20px}
  .col-ko,.col-league{display:none}
  .detail-inner{grid-template-columns:1fr 1fr}
}
</style>
</head>
<body>
<div class="app">

<!-- Hero -->
<section class="hero">
  <div class="hero-inner">
    <div>
      <div class="brand"><h1>GoalScout<span>.v2</span></h1><span class="pill">probability engine</span></div>
      <p>Directional probability engine. Rates each match as Over 2.5 or Under 2.5, calculates fair odds, and identifies edge vs market price.</p>
    </div>
    <div class="hero-right">
      <div class="status"><span class="dot" id="statusDot"></span><span id="statusText">Loading...</span></div>
      <button class="btn" id="refreshBtn" onclick="triggerRefresh()">↻ Refresh</button>
    </div>
  </div>
</section>
<div class="loading-bar" id="loadingBar"></div>

<!-- Tab bar -->
<div style="display:flex;gap:8px;margin-top:14px;margin-bottom:-6px;align-items:center">
  <button class="tab-btn active" id="tabShortlist" onclick="switchTab('shortlist')">📋 Shortlist</button>
  <button class="tab-btn" id="tabPerf" onclick="switchTab('perf')">📊 Performance</button>
  <button class="tab-btn" id="tabSettle" onclick="triggerSettle(this)" style="margin-left:auto;font-size:12px;opacity:.7">↻ Settle now</button>
</div>

<!-- Stats -->
<section class="stats" id="statsSection">
  <div class="stat tone-amber"><div class="stat-label">Shortlisted Matches</div><div class="stat-value" style="color:var(--amber)" id="statShortlisted">—</div></div>
  <div class="stat tone-blue"><div class="stat-label">Last Updated (AEST)</div><div class="stat-value" style="font-size:18px;color:var(--blue)" id="statUpdated">—</div></div>
</section>

<!-- Filters -->
<section class="filters" id="filtersSection">
  <div class="filters-inner">
    <div class="filter-row">
      <div class="filter-group">
        <span class="filter-label">Grade</span>
        <button class="filter-chip active" data-group="grade" data-val="all">All</button>
        <button class="filter-chip" data-group="grade" data-val="A+">A+</button>
        <button class="filter-chip" data-group="grade" data-val="A">A</button>
        <button class="filter-chip" data-group="grade" data-val="B">B</button>
      </div>
      <div class="filter-group">
        <span class="filter-label">Direction</span>
        <button class="filter-chip active" data-group="direction" data-val="all">All</button>
        <button class="filter-chip" data-group="direction" data-val="o25">O2.5</button>
        <button class="filter-chip" data-group="direction" data-val="u25">U2.5</button>
      </div>
    </div>
    <div class="filter-group">
      <span class="filter-label">League</span>
      <select class="league-select" id="leagueFilter" onchange="applyFilters()"><option value="all">All leagues</option></select>
    </div>
  </div>
</section>

<!-- Shortlist accordion -->
<section id="tableShellSection">
  <div class="shortlist-wrap" id="shortlistWrap"></div>
  <div class="empty-state" id="emptyState" style="display:none"><h2>No matches shortlisted</h2><p>No bettable matches meet the threshold. Try refreshing.</p></div>
</section>

<!-- Performance panel -->
<div id="perfPanel" style="display:none;margin-top:14px">
  <div id="perfLoading" style="text-align:center;padding:2rem;color:var(--muted);font-size:14px">Loading performance data...</div>
  <div id="perfContent" style="display:none">
    <div id="perfSummaryCards" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:14px"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px">
      <div id="perfO25Panel" class="perf-market-panel"></div>
      <div id="perfU25Panel" class="perf-market-panel"></div>
    </div>
    <div class="shortlist-wrap" style="margin-top:0">
      <div class="market-tabs">
        <button class="market-tab active" id="perfTabO25" onclick="switchPerfMarketTab('over_2.5')">Over 2.5 Goals</button>
        <button class="market-tab" id="perfTabU25" onclick="switchPerfMarketTab('under_2.5')">Under 2.5 Goals</button>
      </div>
      <div style="padding:10px 18px;font-size:11px;text-transform:uppercase;letter-spacing:.18em;color:var(--muted-2);border-bottom:1px solid var(--line)" id="perfTableLabel">Recent Settled — Over 2.5</div>
      <div class="perf-table-wrap" style="padding:0 0 4px">
        <table class="perf-table" id="perfTable">
          <thead><tr>
            <th>Date</th><th>Match</th><th>Grade</th><th>Dir</th>
            <th style="text-align:right">Model %</th><th style="text-align:right">Fair</th>
            <th style="text-align:right">Tip Odds</th><th style="text-align:right">Edge</th>
            <th style="text-align:right">Pre-KO</th><th style="text-align:right">Move%</th>
            <th style="text-align:right">Close</th><th style="text-align:right">CLV%</th>
            <th style="text-align:center">Score</th><th style="text-align:center">Result</th>
          </tr></thead>
          <tbody id="perfTableBody"></tbody>
        </table>
      </div>
      <div style="padding:10px 18px;font-size:11px;color:var(--muted-2)">
        Move% = tip-time → pre-kickoff price movement. Positive = odds shortened (market agrees). CLV% = how much tip-time beat the closing line. Brier lower = better (0.25 = coin flip).
      </div>
    </div>
  </div>
</div>

<div class="footer">
  <span>Data: <a href="https://www.soccerstats.com" target="_blank">SoccerSTATS</a> · Odds: <a href="https://the-odds-api.com" target="_blank">The-Odds-API</a> · Not betting advice.</span>
  <span>GoalScout v2 · Melbourne AEST</span>
</div>

</div><!-- /app -->

<script>
// ── State ────────────────────────────────────────────────────
let shortlistData=[], filters={grade:'all',direction:'all',league:'all'};
let currentSort={key:'prob',dir:'desc'};
let perfData=null, activePerfMarket='over_2.5';

// ── Helpers ──────────────────────────────────────────────────
function pctClass(v){return v==null?'pct-cold':v>=65?'pct-hot':v>=50?'pct-warm':'pct-cold'}
function gradeClass(g){return g==='A+'?'grade-aplus':g==='A'?'grade-a':g==='B'?'grade-b':'grade-c'}
function fmtPct(v){return v==null?'—':v+'%'}
function fmtVal(v,d=2){return v==null?'—':Number(v).toFixed(d)}
function fmtProbPct(v){return v==null?'—':Math.round(v*100)+'%'}
function flagClass(f){
  if(f.startsWith('🔥')||f.startsWith('📈'))return'hot';
  if(f.startsWith('⚠'))return'warn';
  if(f.startsWith('🔒'))return'lock';
  return'';
}
function stripEmoji(f){return f.replace(/^[🔥📈⚠🔒]\s*/u,'').trim()}
function edgeColor(v){if(v==null)return'var(--muted)';if(v>5)return'var(--green)';if(v>0)return'var(--lime)';if(v>-5)return'var(--amber)';return'var(--red)'}
function clvColor(v){if(v==null)return'var(--muted)';if(v>3)return'var(--green)';if(v>0)return'var(--lime)';if(v>-3)return'var(--amber)';return'var(--red)'}
function moveColor(v){if(v==null)return'var(--muted)';if(v>3)return'var(--green)';if(v>0)return'var(--lime)';if(v<-3)return'var(--red)';return'var(--amber)'}

function fmtKickoff(m){
  if(m.odds&&m.odds.commenceTime){
    var d=new Date(m.odds.commenceTime);
    return d.toLocaleTimeString('en-AU',{hour:'2-digit',minute:'2-digit',hour12:false,timeZone:'Australia/Melbourne'});
  }
  if(!m.kickoff)return'—';
  var p=m.kickoff.split(':').map(Number),h=p[0]-1;
  if(h<0)h=23;
  return String(h).padStart(2,'0')+':'+String(p[1]).padStart(2,'0');
}
function fmtDate(m){
  if(m.odds&&m.odds.commenceTime){
    var d=new Date(m.odds.commenceTime);
    return d.toLocaleDateString('en-AU',{weekday:'short',day:'numeric',month:'short',timeZone:'Australia/Melbourne'});
  }
  return m.day||'';
}

// ── Status polling ────────────────────────────────────────────
async function loadStatus(){
  try{
    var r=await fetch('/api/status');var d=await r.json();
    document.getElementById('statusDot').className='dot '+(d.status==='running'?'running':d.status==='error'?'error':'');
    if(d.status==='running'){
      document.getElementById('statusText').textContent=d.progress||'Refreshing...';
      document.getElementById('loadingBar').classList.add('active');
      document.getElementById('refreshBtn').disabled=true;
    } else {
      document.getElementById('statusText').textContent=d.lastRefresh?'Last: '+new Date(d.lastRefresh).toLocaleTimeString('en-AU',{timeZone:'Australia/Melbourne'}):(d.lastError||'Ready');
      document.getElementById('loadingBar').classList.remove('active');
      document.getElementById('refreshBtn').disabled=false;
    }
    if(d.meta){
      document.getElementById('statShortlisted').textContent=d.meta.shortlistCount||'—';
      if(d.meta.lastRefresh){
        var dt=new Date(d.meta.lastRefresh);
        document.getElementById('statUpdated').textContent=
          dt.toLocaleDateString('en-AU',{day:'2-digit',month:'short',timeZone:'Australia/Melbourne'})+
          ' · '+dt.toLocaleTimeString('en-AU',{hour:'2-digit',minute:'2-digit',timeZone:'Australia/Melbourne'});
      }
    }
    return d.status;
  }catch(e){return'error'}
}

async function loadShortlist(){
  try{var r=await fetch('/api/shortlist');shortlistData=await r.json();populateLeagueFilter();renderShortlist();}catch(e){}
}

function populateLeagueFilter(){
  var s=document.getElementById('leagueFilter');
  var ls=[...new Set(shortlistData.map(m=>m.league))].sort();
  while(s.options.length>1)s.remove(1);
  ls.forEach(l=>{var o=document.createElement('option');o.value=l;o.textContent=l;s.appendChild(o)});
}

function getSortedData(){
  var data=shortlistData.filter(m=>{
    if(filters.grade!=='all'&&m.grade!==filters.grade)return false;
    if(filters.league!=='all'&&m.league!==filters.league)return false;
    if(filters.direction!=='all'&&m.direction!==filters.direction)return false;
    return true;
  });
  var key=currentSort.key, dir=currentSort.dir, mult=dir==='asc'?1:-1;
  return data.sort((a,b)=>{
    var va,vb;
    switch(key){
      case'prob':
        va=a.analysis?((a.direction==='u25'?a.analysis.u25:a.analysis.o25)?.probability||0):0;
        vb=b.analysis?((b.direction==='u25'?b.analysis.u25:b.analysis.o25)?.probability||0):0;break;
      case'grade':{var go={'A+':4,'A':3,'B':2,'C':1};va=go[a.grade]||0;vb=go[b.grade]||0;break;}
      case'kickoff':
        va=a.odds?.commenceTime||a.kickoff||'';
        vb=b.odds?.commenceTime||b.kickoff||'';break;
      case'match':va=a.homeTeam||'';vb=b.homeTeam||'';break;
      case'edge':
        va=a.analysis?((a.direction==='u25'?a.analysis.u25:a.analysis.o25)?.edge??-999):-999;
        vb=b.analysis?((b.direction==='u25'?b.analysis.u25:b.analysis.o25)?.edge??-999):-999;break;
      case'odds':
        va=a.direction==='u25'?a.odds?.u25?.price??0:a.odds?.o25?.price??0;
        vb=b.direction==='u25'?b.odds?.u25?.price??0:b.odds?.o25?.price??0;break;
      default:va=0;vb=0;
    }
    if(typeof va==='string')return mult*va.localeCompare(vb);
    return mult*((va||0)-(vb||0));
  });
}

function setSort(key){
  if(currentSort.key===key){currentSort.dir=currentSort.dir==='desc'?'asc':'desc';}
  else{currentSort={key,dir:'desc'};}
  renderShortlist();
}

function getFilteredData(){return getSortedData();}

// ── Accordion render ──────────────────────────────────────────
function renderShortlist(){
  var wrap=document.getElementById('shortlistWrap');
  var empty=document.getElementById('emptyState');
  var data=getFilteredData();

  if(!data.length){wrap.innerHTML='';empty.style.display='block';return}
  empty.style.display='none';

  function sortClass(k){return currentSort.key===k?currentSort.dir:''}

  var sortBar=`<div class="sort-bar">
    <button class="sort-btn ${sortClass('prob')}" onclick="setSort('prob')">Probability</button>
    <button class="sort-btn ${sortClass('grade')}" onclick="setSort('grade')">Grade</button>
    <span class="sort-label">Call</span>
    <button class="sort-btn ${sortClass('kickoff')}" onclick="setSort('kickoff')">Kickoff</button>
    <span class="sort-label">League</span>
    <button class="sort-btn ${sortClass('match')}" onclick="setSort('match')">Match</button>
    <button class="sort-btn ${sortClass('odds')}" onclick="setSort('odds')">Best Odds</button>
    <button class="sort-btn ${sortClass('edge')}" onclick="setSort('edge')">Edge</button>
    <span></span>
  </div>`;

  wrap.innerHTML=sortBar+data.map((m,i)=>buildMatchRow(m,i)).join('');

  // Attach click listeners (only on summary, not sort bar)
  wrap.querySelectorAll('.row-summary').forEach(function(el){
    el.addEventListener('click',function(){
      var row=el.closest('.match-row');
      row.classList.toggle('open');
    });
  });
}

function buildMatchRow(m,i){
  var isU25=m.direction==='u25';
  var a=m.analysis;
  var mktA=a?(isU25?a.u25:a.o25):null;
  var prob=mktA?.probability;
  var fair=mktA?.fairOdds;
  var edge=mktA?.edge;
  var probPct=prob!=null?Math.round(prob*100):null;
  var probColor=probPct>=65?'var(--green)':probPct>=50?'var(--amber)':'var(--muted)';

  var ko=fmtKickoff(m), dt=fmtDate(m);
  var dirBadge=isU25?'<span class="dir-badge dir-u25">U2.5</span>':'<span class="dir-badge dir-o25">O2.5</span>';

  // O2.5 stats
  var hO=fmtPct(m.home?.o25pct), aO=fmtPct(m.away?.o25pct);
  var bestO25=Math.max(m.home?.o25pct||0, m.away?.o25pct||0);

  // U2.5 stats
  var hCS=fmtPct(m.home?.csPct), aCS=fmtPct(m.away?.csPct);
  var hFTS=fmtPct(m.home?.ftsPct), aFTS=fmtPct(m.away?.ftsPct);
  var bestCS=Math.max(m.home?.csPct||0, m.away?.csPct||0);

  // Odds box
  var oddsData=isU25?m.odds?.u25:m.odds?.o25;
  var oddsHtml='<span style="color:var(--muted-2);font-size:12px;font-style:italic">No odds</span>';
  if(oddsData){
    if(isU25){
      oddsHtml=`<div class="odds-box-u25"><div class="odds-price-u25">${oddsData.price.toFixed(2)}</div><div class="odds-label">${oddsData.bookmaker}</div></div>`;
    } else {
      oddsHtml=`<div class="odds-box"><div class="odds-price">${oddsData.price.toFixed(2)}</div><div class="odds-label">${oddsData.bookmaker}</div></div>`;
    }
  }

  // Edge box
  var edgeHtml='<span style="color:var(--muted-2);font-size:12px;font-style:italic">—</span>';
  if(edge!=null){
    var ec=edgeColor(edge);
    edgeHtml=`<div class="edge-box"><div class="edge-label">Edge</div><div class="edge-val" style="color:${ec}">${edge>0?'+':''}${edge.toFixed(1)}%</div></div>`;
  }

  // Flags — split into positive (hot/lock) and negative (warn)
  var posFlags=(m.flags||[]).filter(f=>!f.startsWith('⚠'));
  var negFlags=(m.flags||[]).filter(f=>f.startsWith('⚠'));
  var flagsHtml=[...posFlags,...negFlags].map(f=>`<span class="flag ${flagClass(f)}">${stripEmoji(f)}</span>`).join('');

  // Links
  var linksHtml='';
  if(m.matchUrl)linksHtml+=`<a href="${m.matchUrl}" target="_blank" rel="noopener" class="action">📊 Match detail</a>`;
  if(m.leagueUrl)linksHtml+=`<a href="${m.leagueUrl}" target="_blank" rel="noopener" class="action">🏆 League page</a>`;
  if(!linksHtml)linksHtml='<span style="color:var(--muted-2);font-size:12px">No links</span>';

  // Combine TG
  var combinedTG=(m.home?.avgTG!=null&&m.away?.avgTG!=null)?
    (m.home.avgTG+m.away.avgTG).toFixed(2):null;

  return `
<div class="match-row" id="mrow-${i}">
  <div class="row-summary">
    <div class="col-prob">
      <div class="prob-big" style="color:${probColor}">${probPct!=null?probPct+'%':'—'}</div>
      <div class="col-prob prob-fair">Fair: ${fair?fair.toFixed(2):'—'}</div>
    </div>
    <div><span class="badge ${gradeClass(m.grade)}">${m.grade}</span></div>
    <div>${dirBadge}</div>
    <div class="col-ko">${ko}<div class="ko-date">${dt}</div></div>
    <div class="col-league"><span title="${m.league||''}">${m.league||m.leagueSlug||'—'}</span></div>
    <div class="col-match">
      <div class="match-title">${m.homeTeam} <span style="color:var(--muted-2)">vs</span> ${m.awayTeam}</div>
    </div>
    <div class="col-odds-summary">${oddsHtml}</div>
    <div class="col-edge-summary">${edgeHtml}</div>
    <div class="chevron">▾</div>
  </div>

  <div class="row-detail">
    <div class="detail-inner">

      <!-- O2.5 Stats -->
      <div class="detail-section">
        <div class="detail-section-title">Over 2.5 Stats</div>
        <div class="stat-box">
          <div class="stat-box-label">Home O2.5%</div>
          <div class="stat-box-val ${pctClass(m.home?.o25pct)}">${hO}</div>
        </div>
        <div class="stat-box">
          <div class="stat-box-label">Away O2.5%</div>
          <div class="stat-box-val ${pctClass(m.away?.o25pct)}">${aO}</div>
        </div>
        ${combinedTG?`<div class="stat-box"><div class="stat-box-label">Combined Avg TG</div><div class="stat-box-val">${combinedTG}</div></div>`:''}
      </div>

      <!-- U2.5 Stats -->
      <div class="detail-section">
        <div class="detail-section-title">Under 2.5 Stats</div>
        <div class="stat-box-u25">
          <div class="stat-box-label">Home CS% / FTS%</div>
          <div class="stat-box-val ${pctClass(bestCS)}">${hCS} <span style="color:var(--muted-2);font-size:11px">cs</span> / ${hFTS} <span style="color:var(--muted-2);font-size:11px">fts</span></div>
        </div>
        <div class="stat-box-u25">
          <div class="stat-box-label">Away CS% / FTS%</div>
          <div class="stat-box-val ${pctClass(bestCS)}">${aCS} <span style="color:var(--muted-2);font-size:11px">cs</span> / ${aFTS} <span style="color:var(--muted-2);font-size:11px">fts</span></div>
        </div>
      </div>

      <!-- Pricing detail (margin info) -->
      <div class="detail-section">
        <div class="detail-section-title">Pricing Detail</div>
        <div class="stat-box">
          <div class="stat-box-label">Model probability</div>
          <div class="stat-box-val" style="color:${probColor}">${probPct!=null?probPct+'%':'—'}</div>
        </div>
        <div class="stat-box">
          <div class="stat-box-label">Fair odds</div>
          <div class="stat-box-val">${fair?fair.toFixed(2):'—'}</div>
        </div>
        ${a?.marketMarginPct!=null?`<div style="font-size:11px;color:var(--muted-2);margin-top:4px">Market margin: ${a.marketMarginPct}%</div>`:''}
      </div>

      <!-- Flags + Links -->
      <div class="detail-section">
        <div class="detail-section-title">Signals</div>
        <div class="flags">${flagsHtml||'<span style="color:var(--muted-2);font-size:12px">No flags</span>'}</div>
        <div style="margin-top:10px">
          <div class="detail-section-title">Links</div>
          <div class="links">${linksHtml}</div>
        </div>
      </div>

    </div>
  </div>
</div>`;
}

// ── Filters ───────────────────────────────────────────────────
function applyFilters(){filters.league=document.getElementById('leagueFilter').value;renderShortlist()}
document.querySelectorAll('.filter-chip').forEach(chip=>{
  chip.addEventListener('click',()=>{
    var group=chip.dataset.group;
    document.querySelectorAll(`.filter-chip[data-group="${group}"]`).forEach(c=>c.classList.remove('active'));
    chip.classList.add('active');
    filters[group]=chip.dataset.val;
    renderShortlist();
  });
});

// ── Refresh ───────────────────────────────────────────────────
async function triggerRefresh(){document.getElementById('refreshBtn').disabled=true;await fetch('/api/refresh',{method:'POST'});pollUntilDone()}
async function pollUntilDone(){var s=await loadStatus();if(s==='running')setTimeout(pollUntilDone,2000);else await loadShortlist()}

// ── Tab switching ──────────────────────────────────────────────
function switchTab(tab){
  document.getElementById('tabShortlist').classList.toggle('active',tab==='shortlist');
  document.getElementById('tabPerf').classList.toggle('active',tab==='perf');
  var isSL=tab==='shortlist';
  document.getElementById('statsSection').style.display=isSL?'':'none';
  document.getElementById('filtersSection').style.display=isSL?'':'none';
  document.getElementById('tableShellSection').style.display=isSL?'':'none';
  document.getElementById('emptyState').style.display='none';
  document.getElementById('perfPanel').style.display=isSL?'none':'';
  if(!isSL)loadPerformance();
}

// ── Settle ─────────────────────────────────────────────────────
async function triggerSettle(btn){
  btn.disabled=true;btn.textContent='⟳ Settling...';
  try{var r=await fetch('/api/settle',{method:'POST'});var d=await r.json();
    btn.textContent=`✓ ${d.settled||0} settled`;
    if(document.getElementById('tabPerf').classList.contains('active'))loadPerformance();
  }catch(e){btn.textContent='✗ Error';}
  setTimeout(()=>{btn.textContent='↻ Settle now';btn.disabled=false;},3000);
}

// ── Performance tab ────────────────────────────────────────────
function switchPerfMarketTab(market){
  activePerfMarket=market;
  var isU25=market==='under_2.5';
  document.getElementById('perfTabO25').className='market-tab'+(market==='over_2.5'?' active':'');
  document.getElementById('perfTabU25').className='market-tab'+(isU25?' active-u25':'');
  document.getElementById('perfTableLabel').textContent=isU25?'Recent Settled — Under 2.5':'Recent Settled — Over 2.5';
  if(perfData)renderPerfTable(perfData.recentSettled||[]);
}

async function loadPerformance(){
  document.getElementById('perfLoading').style.display='block';
  document.getElementById('perfContent').style.display='none';
  try{var r=await fetch('/api/stats');perfData=await r.json();renderPerformance(perfData);}
  catch(e){document.getElementById('perfLoading').textContent='Failed to load performance data.';}
}

function renderPerformance(d){
  var s=d.summary||{},o25=d.markets?.['over_2.5']||{},u25=d.markets?.['under_2.5']||{};

  var cards=[
    {label:'Total Predictions',value:s.total||0,sub:'across both markets',color:'var(--cyan)'},
    {label:'Settled',value:s.settled||0,sub:`${s.pending||0} pending · ${s.awaiting||0} awaiting`,color:'var(--blue)'},
    {label:'Void Rate',value:s.voidRatePct!=null?s.voidRatePct+'%':'—',sub:`${s.void||0} voids`,color:s.voidRatePct>10?'var(--amber)':'var(--muted)'},
    {label:'Overall Hit Rate',value:s.settled>0?Math.round(s.won/s.settled*1000)/10+'%':'—',sub:`${s.won||0} of ${s.settled||0}`,color:'var(--green)'},
  ];
  document.getElementById('perfSummaryCards').innerHTML=cards.map(c=>
    `<div class="perf-card"><div class="perf-card-label">${c.label}</div><div class="perf-card-value" style="color:${c.color}">${c.value}</div><div class="perf-card-sub">${c.sub}</div></div>`
  ).join('');

  function mktPanel(label,m,accent,id){
    var rows=[
      ['Predictions',fmtVal(m.total,0)],
      ['Settled',fmtVal(m.settled,0)],
      ['Pending / Awaiting',`${m.pending||0} / ${m.awaiting||0}`],
      ['Hit rate',m.hitRate!=null?`<span style="color:${m.hitRate>=55?'var(--green)':m.hitRate>=45?'var(--amber)':'var(--red)'}">${m.hitRate}%</span>`:'—'],
      ['Mean model prob',m.meanModelProb!=null?m.meanModelProb+'%':'—'],
      ['Brier score',m.brierScore!=null?String(m.brierScore):'— <span style="font-size:11px;color:var(--muted-2)">(need data)</span>'],
      ['Mean edge at tip',m.meanEdgePct!=null?`<span style="color:${edgeColor(m.meanEdgePct)}">${m.meanEdgePct>0?'+':''}${m.meanEdgePct}%</span>`:'—'],
      ['Mean pre-KO move',m.meanPreKickoffMovePct!=null?`<span style="color:${moveColor(m.meanPreKickoffMovePct)}">${m.meanPreKickoffMovePct>0?'+':''}${m.meanPreKickoffMovePct}%</span>`:'—'],
      ['Mean CLV',m.meanCLVPct!=null?`<span style="color:${clvColor(m.meanCLVPct)}">${m.meanCLVPct>0?'+':''}${m.meanCLVPct}%</span>`:'— <span style="font-size:11px;color:var(--muted-2)">(need closing odds)</span>'],
    ];
    return`<div class="perf-market-panel" id="${id}"><div style="font-size:14px;font-weight:700;margin-bottom:12px;color:${accent}">${label}</div>${rows.map(([l,v])=>`<div class="perf-row"><span class="perf-row-label">${l}</span><span class="perf-row-val">${v}</span></div>`).join('')}</div>`;
  }

  document.getElementById('perfO25Panel').outerHTML=mktPanel('Over 2.5 Goals',o25,'var(--green)','perfO25Panel');
  document.getElementById('perfU25Panel').outerHTML=mktPanel('Under 2.5 Goals',u25,'var(--indigo)','perfU25Panel');

  renderPerfTable(d.recentSettled||[]);
  document.getElementById('perfLoading').style.display='none';
  document.getElementById('perfContent').style.display='block';
}

function renderPerfTable(all){
  var rows=all.filter(p=>p.market===activePerfMarket);
  var tbody=document.getElementById('perfTableBody');
  if(!rows.length){
    tbody.innerHTML=`<tr><td colspan="14" style="text-align:center;padding:2rem;color:var(--muted);font-size:13px">No settled ${activePerfMarket==='over_2.5'?'Over 2.5':'Under 2.5'} predictions yet.</td></tr>`;
    return;
  }
  tbody.innerHTML=rows.map(p=>{
    var edgeStr=p.edge!=null?`<span style="color:${edgeColor(p.edge)}">${p.edge>0?'+':''}${p.edge.toFixed(1)}%</span>`:'—';
    var clvStr=p.clvPct!=null?`<span style="color:${clvColor(p.clvPct)}">${p.clvPct>0?'+':''}${p.clvPct.toFixed(1)}%</span>`:'—';
    var moveStr=p.preKickoffMovePct!=null?`<span style="color:${moveColor(p.preKickoffMovePct)}">${p.preKickoffMovePct>0?'+':''}${p.preKickoffMovePct.toFixed(1)}%</span>`:'—';
    var resultBadge=p.status==='settled_won'?'<span style="color:var(--green);font-weight:700">✓ Won</span>':p.status==='settled_lost'?'<span style="color:var(--red);font-weight:700">✗ Lost</span>':'—';
    var grade=p.inputs?.grade||p.grade||'—';
    var gradeHtml=`<span class="badge ${gradeClass(grade)}" style="font-size:11px;padding:4px 8px">${grade}</span>`;
    var dirHtml=p.direction==='u25'?'<span class="dir-badge dir-u25" style="font-size:10px;padding:3px 7px">U2.5</span>':'<span class="dir-badge dir-o25" style="font-size:10px;padding:3px 7px">O2.5</span>';
    return`<tr>
<td style="color:var(--muted-2);font-size:12px">${p.predictionDate}</td>
<td style="font-weight:600">${p.homeTeam} vs ${p.awayTeam}</td>
<td>${gradeHtml}</td>
<td>${dirHtml}</td>
<td style="text-align:right;font-weight:700">${fmtProbPct(p.modelProbability)}</td>
<td style="text-align:right;color:var(--muted)">${fmtVal(p.fairOdds)}</td>
<td style="text-align:right;color:var(--violet)">${fmtVal(p.marketOdds)}</td>
<td style="text-align:right">${edgeStr}</td>
<td style="text-align:right;color:var(--muted)">${fmtVal(p.preKickoffOdds)}</td>
<td style="text-align:right">${moveStr}</td>
<td style="text-align:right;color:var(--muted)">${fmtVal(p.closingOdds)}</td>
<td style="text-align:right">${clvStr}</td>
<td style="text-align:center;font-weight:700;color:var(--cyan)">${p.score||'—'}</td>
<td style="text-align:center">${resultBadge}</td>
</tr>`;
  }).join('');
}

// ── Init ──────────────────────────────────────────────────────
async function init(){
  var s=await loadStatus();
  await loadShortlist();
  if(s==='running')pollUntilDone();
  setInterval(loadStatus,30000);
}
init();
</script>
</body>
</html>
