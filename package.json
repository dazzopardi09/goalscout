{
  "name": "goalscout",
  "version": "1.0.0",
  "description": "Football match investigation tool — Over 2.5 & Under 2.5 shortlisting from SoccerSTATS",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "scrape": "node src/scrape-cli.js",
    "backtest": "node src/analysis/backtest.js",
    "backtest:save": "node src/analysis/backtest.js --output data/history/backtest-report.json",
    "replay": "node src/replay/runner.js",
    "replay:dry": "node src/replay/runner.js --dry-run --limit 10",
    "replay:settle": "node src/replay/settler.js",
    "replay:settle:dry": "node src/replay/settler.js --dry-run"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "undici": "^6.19.0"
  }
}